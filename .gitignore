# ============================================================
# .gitignore — Visual Studio C/C++ Project
# ============================================================

# ── Build output directories ────────────────────────────────
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# ── Compiled object files ───────────────────────────────────
*.obj
*.o
*.ko
*.elf

# ── Precompiled headers ─────────────────────────────────────
*.gch
*.pch

# ── Linker output ───────────────────────────────────────────
*.ilk
*.map
*.exp

# ── Executables ─────────────────────────────────────────────
*.exe
*.out
*.app

# ── Debug symbols ───────────────────────────────────────────
*.pdb
*.idb
*.ipdb
*.pgc
*.pgd

# ── Static and shared libraries ─────────────────────────────
*.lib
*.a
*.la
*.lo
*.dll
*.so
*.so.*

# ── Visual Studio local files ───────────────────────────────
.vs/
*.user
*.suo
*.aps
*.ncb
*.sdf
*.opensdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# ── Visual Studio build logs and tlog files ─────────────────
*.tlog
*.lastbuildstate
*.BuildLog.htm
*.log
ipch/

# ── Visual Studio temp/IntelliSense ─────────────────────────
*.vcxproj.filters.bak
*.vcxproj.bak
*.vsp
*.vspx
*.sap

# ── NuGet packages ──────────────────────────────────────────
packages/
*.nupkg
project.lock.json

# ── CMake ───────────────────────────────────────────────────
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/

# ── Windows OS files ────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── macOS (if collaborating cross-platform) ─────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Keep these in the repo ──────────────────────────────────
# Source files:      *.c  *.h  *.cpp  *.hpp
# Project files:     *.sln  *.vcxproj
# Documentation:     *.md  *.pdf  *.txt
# Flowchart:         flowchart.svg
!*.c
!*.h
!*.cpp
!*.hpp
!*.sln
!*.vcxproj
!*.md
!*.pdf
!*.svg
!*.txt
Code/Documents/
